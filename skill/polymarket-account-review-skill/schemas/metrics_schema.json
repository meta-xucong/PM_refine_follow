{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PolymarketAccountMetrics",
  "type": "object",
  "required": [
    "account_address",
    "analysis_window",
    "trade_rows_used",
    "total_buy_usdc",
    "total_sell_usdc",
    "metrics"
  ],
  "properties": {
    "account_address": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" },
    "analysis_window": { "type": "string" },
    "trade_rows_used": { "type": "integer", "minimum": 0 },
    "total_buy_usdc": { "type": "number" },
    "total_sell_usdc": { "type": "number" },
    "api_summary": {
      "type": ["object", "null"],
      "properties": {
        "positions_value": { "type": ["number", "null"] },
        "traded_markets": { "type": ["integer", "null"] }
      },
      "additionalProperties": true
    },
    "metrics": {
      "type": "object",
      "required": [
        "dual_side_buy_usdc_ratio",
        "exclusive_concurrent_leg_ratio",
        "nested_concurrent_leg_ratio",
        "weighted_multi_market_risk_ratio",
        "deployable_event_equivalent",
        "deployable_event_density"
      ],
      "properties": {
        "dual_side_condition_count_ratio": { "type": ["number", "null"] },
        "dual_side_buy_usdc_ratio": { "type": ["number", "null"] },
        "dual_side_buy_usdc_ratio_1h": { "type": ["number", "null"] },
        "token_fast_20m_count": { "type": ["integer", "null"] },
        "token_fast_20m_buy_usdc_ratio": { "type": ["number", "null"] },
        "token_fast_20m_sell_usdc_ratio": { "type": ["number", "null"] },
        "noncopyable_token_fast_buy_ratio": { "type": ["number", "null"] },
        "noncopyable_token_fast_sell_ratio": { "type": ["number", "null"] },
        "noncopyable_token_fast_token_ratio": { "type": ["number", "null"] },
        "event_rebalance_20m_event_ratio": { "type": ["number", "null"] },
        "exclusive_multi_market_buy_ratio": { "type": ["number", "null"] },
        "nested_deadline_multi_market_buy_ratio": { "type": ["number", "null"] },
        "independent_multi_market_buy_ratio": { "type": ["number", "null"] },
        "unknown_multi_market_buy_ratio": { "type": ["number", "null"] },
        "exclusive_concurrent_leg_ratio": { "type": ["number", "null"] },
        "nested_concurrent_leg_ratio": { "type": ["number", "null"] },
        "exclusive_overlap_time_ratio": { "type": ["number", "null"] },
        "nested_overlap_time_ratio": { "type": ["number", "null"] },
        "weighted_multi_market_risk_ratio": { "type": ["number", "null"] },
        "exclusive_sequential_switch_count": { "type": ["integer", "null"] },
        "nested_sequential_roll_count": { "type": ["integer", "null"] },
        "median_holding_time_sec": { "type": ["number", "null"] },
        "weighted_median_holding_time_sec": { "type": ["number", "null"] },
        "sell_usdc_ratio_within_20m": { "type": ["number", "null"] },
        "sell_usdc_ratio_within_1h": { "type": ["number", "null"] },
        "clean_event_count": { "type": "integer" },
        "semiclean_event_count": { "type": "integer" },
        "dirty_event_count": { "type": "integer" },
        "deployable_event_equivalent": { "type": "number" },
        "deployable_event_density": { "type": "number" },
        "trade_count": { "type": ["number", "null"] },
        "active_trading_days": { "type": ["number", "null"] },
        "active_day_ratio": { "type": ["number", "null"] },
        "avg_trades_per_active_day": { "type": ["number", "null"] },
        "top1_event_buy_ratio": { "type": ["number", "null"] },
        "top3_event_buy_ratio": { "type": ["number", "null"] }
      },
      "additionalProperties": true
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
